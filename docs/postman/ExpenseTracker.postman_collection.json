{
  "info": {
    "name": "Expense Tracker API",
    "description": "Complete API test suite for the Expense Tracker application.\n\nSetup:\n1. Set the 'baseUrl' variable to your API URL (default: https://localhost:5001/api)\n2. Run 'Register' or 'Login' first — the token is saved automatically\n3. All other requests use the saved token",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "https://localhost:5001/api" },
    { "key": "token",   "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "pm.collectionVariables.set('token', json.token);",
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('Has token', () => pm.expect(json.token).to.be.a('string'));"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\"\n}" }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": [
            "var json = pm.response.json();",
            "pm.collectionVariables.set('token', json.token);",
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Statements",
      "item": [
        {
          "name": "Upload PNC CSV",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/statements/upload",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "../sample-pnc.csv" },
                { "key": "bankName", "value": "PNC", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Get Statements",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/statements",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Get All Transactions",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/transactions?page=1&pageSize=20", "query": [
              { "key": "page", "value": "1" },
              { "key": "pageSize", "value": "20" },
              { "key": "search", "value": "", "disabled": true },
              { "key": "categoryId", "value": "", "disabled": true }
            ]},
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
          }
        },
        {
          "name": "Search Transactions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/transactions?search=starbucks",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Dashboard Summary",
          "request": { "method": "GET", "url": "{{baseUrl}}/analytics/dashboard", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }}
        },
        {
          "name": "Monthly Analytics",
          "request": { "method": "GET", "url": "{{baseUrl}}/analytics/monthly?year=2025&month=3", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }}
        },
        {
          "name": "Yearly Analytics",
          "request": { "method": "GET", "url": "{{baseUrl}}/analytics/yearly?year=2025", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }}
        }
      ]
    },
    {
      "name": "Budgets",
      "item": [
        {
          "name": "Get Budgets",
          "request": { "method": "GET", "url": "{{baseUrl}}/budgets?year=2025&month=3", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }}
        },
        {
          "name": "Create Budget",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/budgets",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"categoryId\": 1,\n  \"monthlyLimit\": 500,\n  \"month\": 3,\n  \"year\": 2025\n}" }
          }
        }
      ]
    },
    {
      "name": "Alerts",
      "item": [
        {
          "name": "Get Alerts",
          "request": { "method": "GET", "url": "{{baseUrl}}/alerts", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }}
        },
        {
          "name": "Mark All Read",
          "request": { "method": "PUT", "url": "{{baseUrl}}/alerts/read-all", "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }}
        }
      ]
    }
  ]
}
