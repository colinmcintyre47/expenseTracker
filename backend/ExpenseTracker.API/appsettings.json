{
  /*
   * Production configuration file.
   * Sensitive values (connection string, JWT secret) should be overridden
   * using environment variables or a secrets manager in production.
   * Never commit real secrets to source control.
   */
  "ConnectionStrings": {
    /*
     * MySQL connection string.
     * Format: server=HOST;port=3306;database=DB_NAME;user=USER;password=PASSWORD
     * Override this via the environment variable:
     *   ConnectionStrings__DefaultConnection=...
     */
    "DefaultConnection": "server=localhost;port=3306;database=expense_tracker;user=root;password=yourpassword"
  },
  "JwtSettings": {
    /*
     * Secret key used to sign JWT tokens.
     * MUST be at least 32 characters long and kept secret.
     * Override via environment variable: JwtSettings__Secret=...
     */
    "Secret": "REPLACE_WITH_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS",
    "Issuer": "ExpenseTrackerAPI",
    "Audience": "ExpenseTrackerClient",
    /* Token expiry in minutes — 1440 = 24 hours */
    "ExpiryMinutes": 1440
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
